// Logic to handle saving to LocalStorage
export const saveMoodLog = (entry) => {
  const existingLogs = JSON.parse(localStorage.getItem('moodLogs') || '[]');
  const newLog = {
    ...entry,
    id: Date.now(),
    date: new Date().toISOString()
  };
  localStorage.setItem('moodLogs', JSON.stringify([newLog, ...existingLogs]));
  return newLog;
};

// Logic to get insights (Example: Most frequent mood)
export const getWeeklyInsights = (logs) => {
  if (logs.length === 0) return "No data yet.";
  const counts = logs.reduce((acc, log) => {
    acc[log.core] = (acc[log.core] || 0) + 1;
    return acc;
  }, {});
  return Object.keys(counts).reduce((a, b) => counts[a] > counts[b] ? a : b);
};
